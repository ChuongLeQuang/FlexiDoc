{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🛡️ Chạy Kiểm Tra Tự Động (Auto Checks)",
            "type": "shell",
            "command": "${workspaceFolder}\\.venv\\Scripts\\python",
            "args": [
                "auto_checks.py"
            ],
            "problemMatcher": []
        },
        {
            "label": "🚀 Build Executable (.exe)",
            "type": "shell",
            "command": "python build.py",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "🔍 Cập nhật Architecture (README.md)",
            "type": "shell",
            "command": "python scan_architecture.py",
            "problemMatcher": []
        },
        {
            "label": "🧪 Chạy Unit Test (Pytest)",
            "type": "shell",
            "command": "${workspaceFolder}\\.venv\\Scripts\\pytest",
            "args": [
                "tests/"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "🔄 Sync to GitHub",
            "type": "shell",
            "command": ".\\sync.bat",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "🎉 Khởi tạo & Đẩy Code Lần Đầu Lên GitHub",
            "type": "shell",
            "command": ".\\init_github.bat",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": []
        }
    ]
}